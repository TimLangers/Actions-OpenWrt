# ======================
# Target
# ======================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ======================
# Kernel / rootfs
# ======================
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=2048
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_GRUB_IMAGES=y
CONFIG_GRUB_EFI_IMAGES=y
CONFIG_GRUB_TIMEOUT="3"

# ======================
# LuCI base
# ======================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=n          # 已废弃，显式禁用
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-network=y

# ======================
# Language (zh_Hans)
# ======================
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-firewall-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-opkg-zh_Hans=y

# ======================
# Theme (Argon)
# ======================
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh_Hans=y

# ======================
# Apps (Only OpenClash & Remove PassWall)
# ======================
CONFIG_PACKAGE_luci-app-openclash=y

# 🚫 显式禁用 PassWall 及其核心依赖，防止混入
CONFIG_PACKAGE_luci-app-passwall=n
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=n
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=n
CONFIG_PACKAGE_passwall=n
CONFIG_PACKAGE_passwall-vray-plugin=n
CONFIG_PACKAGE_passwall-xray-plugin=n

# ======================
# DNS (避免冲突)
# ======================
CONFIG_PACKAGE_dnsmasq=n
CONFIG_PACKAGE_dnsmasq-full=y

# ======================
# Network essentials
# ======================
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_dropbear=y

# ======================
# Drivers (x86 常用)
# ======================
CONFIG_PACKAGE_kmod-igb=y
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-r8169=y
CONFIG_PACKAGE_kmod-e1000e=y
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-pci=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-nvme=y

# ======================
# Filesystem
# ======================
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# ======================
# Tools
# ======================
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_unzip=y

# ======================
# Performance
# ======================
CONFIG_DEVEL=y
CONFIG_CCACHE=y
